# Copy to `.env.prod` for deployment: cp .env.prod.example .env.prod
# Read locally by Compose at deploy time and passed to the container as env vars.
# Keep it secret (gitignored).

# --- Database (Postgres container) ---
# Use a strong password; it must match the one embedded in DATABASE_URL below.
POSTGRES_USER="arranger"
POSTGRES_PASSWORD="change-me-strong"
POSTGRES_DB="arranger"
# Host MUST be `db` — the Postgres service name on the compose network.
DATABASE_URL="postgres://arranger:change-me-strong@db:5432/arranger"

# --- Auth ---
AUTH_SECRET="change-me"   # generate with: openssl rand -hex 32

# --- Email (Resend — https://resend.com) ---
# Verify your sending domain in Resend (add SPF + DKIM records, ideally DMARC)
# so verification emails send and don't land in spam.
RESEND_API_KEY="re_..."
EMAIL_FROM="hello@your-domain.com"

# --- OAuth (optional; configure the providers you want, or leave blank) ---
# Create the apps: Google → Cloud Console → Credentials; GitHub → Settings →
# Developer settings → OAuth Apps. Register the redirect URI byte-for-byte:
#   https://your-domain.com/auth/api/google/callback
#   https://your-domain.com/auth/api/github/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
